

enum E_INV_COLORS{
	icColor_Main_Background,        //цвет главного заднего фона
    icColor_Main_Foreground,        //цвет фона наложения
    icColor_Text,               	//цвет текста

    icColor_Slot_Background, 		//цвет заднего фона слотов
    icColor_Slot_Foreground, 		//цвет переднего фона слотов
    icColor_Slot_Selected,  		//цвет заднего фона выбранного слота
	
    icColor_Cursor,             	//цвет курсора
    icColor_SmallStriped        	//цвет маленьких разделительных полосок
}
new InventoryColors[2][E_INV_COLORS];
